# Fastlane configuration for VoiceMate
# Full automated: build → sign → upload to App Store Connect

default_platform(:ios)

platform :ios do
  desc "Build and sign the app"
  lane :build_app do
    # Generate Xcode project from Package.swift
    sh("cd .. && swift package generate-xcodeproj 2>/dev/null || true")

    # Set version
    increment_version_number(
      version_number: ENV["APP_VERSION"] || "1.0.0",
      xcodeproj: "VoiceMate.xcodeproj"
    )
    increment_build_number(
      build_number: ENV["BUILD_NUMBER"] || ENV["GITHUB_RUN_NUMBER"] || "1",
      xcodeproj: "VoiceMate.xcodeproj"
    )

    # Build with automatic code signing
    gym(
      project: "VoiceMate.xcodeproj",
      scheme: "VoiceMate",
      configuration: "Release",
      export_method: "app-store",
      clean: true,
      include_symbols: true,
      output_directory: "./build",
      output_name: "VoiceMate.ipa",
      xcargs: [
        "DEVELOPMENT_TEAM=#{ENV['APPLE_TEAM_ID']}",
        "CODE_SIGN_STYLE=Automatic",
        "PROVISIONING_PROFILE_SPECIFIER="
      ].join(" ")
    )
  end

  desc "Upload IPA to App Store Connect"
  lane :upload_app do
    api_key = app_store_connect_api_key(
      key_id: ENV["APPSTORE_KEY_ID"],
      issuer_id: ENV["APPSTORE_ISSUER_ID"],
      key_filepath: File.expand_path("~/.appstoreconnect/AuthKey_#{ENV['APPSTORE_KEY_ID']}.p8"),
      duration: 1200,
      in_house: false
    )

    upload_to_app_store(
      api_key: api_key,
      ipa: "./build/VoiceMate.ipa",
      skip_metadata: true,
      skip_screenshots: true,
      force: true,
      precheck_include_in_app_purchases: false,
      submission_information: {
        add_id_info_uses_idfa: false,
        export_compliance_encryption_updated: false,
        export_compliance_uses_encryption: false
      }
    )
  end

  desc "Full pipeline: build + upload + submit"
  lane :release do
    build_app
    upload_app

    # Submit for review (uncomment when ready)
    # deliver(
    #   submit_for_review: true,
    #   automatic_release: false,
    #   api_key: app_store_connect_api_key(...)
    # )
  end
end
